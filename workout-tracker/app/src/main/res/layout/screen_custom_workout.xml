<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/customWorkoutPanel"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:background="@color/hud_background">

    <TextView
        android:id="@+id/customWorkoutPromptView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:gravity="center"
        android:text="@string/custom_workout_name_prompt"
        android:textColor="@color/hud_foreground"
        android:textSize="18dp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/customWorkoutVoiceHintView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:textColor="@color/hud_foreground_muted"
        android:textSize="14dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="12dp"
        android:background="@color/hud_foreground_muted" />

    <TextView
        android:id="@+id/customWorkoutResultView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fontFamily="monospace"
        android:gravity="center"
        android:textColor="@color/hud_foreground"
        android:textSize="14dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/customWorkoutErrorView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:textSize="14dp"
        android:visibility="gone" />
</LinearLayout>
