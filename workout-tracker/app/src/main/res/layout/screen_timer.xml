<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/timerPanel"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical">

    <TextView
        android:id="@+id/timerCountdownView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:fontFamily="monospace"
        android:textColor="@color/hud_foreground"
        android:textSize="56dp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/timerExerciseInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:fontFamily="monospace"
        android:textColor="@color/hud_foreground_muted"
        android:textSize="12dp" />

    <TextView
        android:id="@+id/timerLabelView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:fontFamily="monospace"
        android:textColor="@color/hud_foreground_muted"
        android:textSize="14dp"
        android:text="@string/timer_skip_label" />

    <FrameLayout
        android:id="@+id/timerProgressContainer"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="24dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp">

        <View
            android:id="@+id/timerProgressBar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/hud_foreground_muted" />

        <View
            android:id="@+id/timerProgressFill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@color/hud_accent" />
    </FrameLayout>
</LinearLayout>
