[*.{kt,kts}]
indent_size = 4
indent_style = space
max_line_length = 160
continuation_indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
[*.xml]
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
[*.{yml,yaml}]
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
